# ExifTool GUI — Umgebungsvariablen
# Kopieren nach .env und anpassen:
#   cp .env.example .env
#
# In Dockhand können diese Werte auch als "Config Set" hinterlegt werden
# (Settings > Config Sets) ohne eine .env-Datei im Repo zu benötigen.

# X11 Display (normalerweise :0 auf Linux-Desktop)
DISPLAY=:0

# Host-Verzeichnis mit deinen Fotos
# Wird als /photos in den Container gemountet
# Beispiele:
#   PHOTOS_DIR=/home/user/Pictures
#   PHOTOS_DIR=/mnt/nas/fotos
#   PHOTOS_DIR=/volume1/photos          # Synology
PHOTOS_DIR=/volume1/photos

# Datenpfad für persistente App-Konfiguration
# MUSS auf dem Host existieren bevor der Stack gestartet wird!
#
# Synology:
#   mkdir -p /volume1/docker/exiftool-gui/data
# Linux:
#   mkdir -p /opt/docker/exiftool-gui/data
#
STACK_DATA_DIR=/volume1/docker/exiftool-gui/data
